# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.yarn/
.npm/

# ─── Build output ───────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ─── PWA / service-worker generated ─────────────────────────────────────────
dev-dist/
public/sw.js
public/workbox-*.js
public/registerSW.js

# ─── TypeScript / Vite caches ───────────────────────────────────────────────
*.tsbuildinfo
.vite/
.cache/

# ─── Vitest / coverage ──────────────────────────────────────────────────────
coverage/
.vitest/
.nyc_output/

# ─── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Env / secrets ──────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.p12
*.key

# ─── GCP / Firebase credentials (never commit) ──────────────────────────────
serviceAccount.json
serviceAccount*.json
*-serviceAccount.json
*service-account*.json
*service_account*.json
firebase-adminsdk-*.json
.firebase/
.runtimeconfig.json
.gcloudignore

# ─── Editors / OS ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ─── Misc local ─────────────────────────────────────────────────────────────
*.local

# ─── User data files ────────────────────────────────────────────────────────
# The app's data file (idrive.xlsx) must never be committed — it contains
# personal/group data and is managed by the user outside the repo.
*.xlsx

# ─── Group membership (PII — emails) ────────────────────────────────────────
# `families.yaml` is the source of truth for authorised emails. The generated
# `src/familiesData.ts` ships in the production bundle but should NOT live in
# the source repo (avoids leaking emails via GitHub). Both are rebuilt by
# `./run.sh --firebase` from the local `families.yaml`.
families.yaml
src/familiesData.ts
