# ──────────────────────────────────────────────────────────────────────────
# Gradle
# ──────────────────────────────────────────────────────────────────────────
.gradle/
.gradle-*/
build/
*/build/
app/build/
# keep the wrapper jar (standard practice)
!gradle/wrapper/gradle-wrapper.jar

# ──────────────────────────────────────────────────────────────────────────
# Kotlin / KSP / annotation processing
# ──────────────────────────────────────────────────────────────────────────
.kotlin/
kotlin-js-store/
generated/
*/generated/
kspCaches/

# ──────────────────────────────────────────────────────────────────────────
# Android / IntelliJ / Android Studio
# ──────────────────────────────────────────────────────────────────────────
local.properties
.idea/
*.iml
*.iws
*.ipr
.navigation/
captures/
/captures
.externalNativeBuild/
.cxx/
lint-results*.html
lint-results*.xml

# Android app build artefacts (in case they land outside app/build/)
release/
debug/

# ──────────────────────────────────────────────────────────────────────────
# Docker build scaffolding (created by docker-* Makefile targets)
# ──────────────────────────────────────────────────────────────────────────
.docker-home/
.gradle-docker/

# ──────────────────────────────────────────────────────────────────────────
# Signing — NEVER commit secrets or keystores
# ──────────────────────────────────────────────────────────────────────────
keystore/
*.jks
*.keystore
signing.local.properties
*.p12
*.pem
*.key

# ──────────────────────────────────────────────────────────────────────────
# Build outputs & distribution artifacts
#   `out/` is the canonical location for final APKs / AABs / dist bundles
# ──────────────────────────────────────────────────────────────────────────
out/
dist/
artifacts/
*.apk
*.aab
*.ap_
*.dex
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
bin/
gen/
proguard/
proguard-project.txt

# ──────────────────────────────────────────────────────────────────────────
# Google services — project-specific, never commit
# ──────────────────────────────────────────────────────────────────────────
app/google-services.json
google-services.json

# ──────────────────────────────────────────────────────────────────────────
# Test reports
# ──────────────────────────────────────────────────────────────────────────
test-results/
reports/
*/test-results/
*/reports/

# ──────────────────────────────────────────────────────────────────────────
# Editors / IDEs
# ──────────────────────────────────────────────────────────────────────────
.vscode/
.fleet/
*.sublime-project
*.sublime-workspace
.metadata/

# ──────────────────────────────────────────────────────────────────────────
# OS cruft
# ──────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────────────────
# Logs & temp files
# ──────────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
hs_err_pid*.log
emulator.log

# ──────────────────────────────────────────────────────────────────────────
# Claude Code / AI tooling caches
# ──────────────────────────────────────────────────────────────────────────
.claude/
.claude-code/
