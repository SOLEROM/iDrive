{
  "name": "kids-rides-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Kids Rides & Classes Manager — Progressive Web App",
  "scripts": {
    "dev": "vite",
    "dev:https": "HTTPS=1 vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173 --host",
    "preview:https": "HTTPS=1 vite preview --port 4173 --host",
    "icons": "node scripts/generate-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "dexie": "^4.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^2.0.5"
  }
}
